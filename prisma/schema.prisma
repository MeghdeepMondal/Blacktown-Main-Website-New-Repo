generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model adminrequests {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  address        String
  bannerPhoto    String?  // Cloudinary URL for banner/cover photo
  contactDetails String
  createdAt      DateTime @db.Date
  description    String
  email          String   @unique
  lat            Float
  lng            Float
  logo           String?  // Cloudinary URL for profile photo
  name           String
  password       String
  status         String
  updatedAt      DateTime @db.Date
  websiteLink    String?  // Organization website URL
}

model admins {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  address        String?
  bannerPhoto    String?   // Cloudinary URL for banner/cover photo
  contactDetails String?
  createdAt      DateTime? @db.Date
  description    String?
  email          String    @unique
  lat            Float?
  lng            Float?
  logo           String?   // Cloudinary URL for profile photo
  name           String
  password       String
  updatedAt      DateTime? @db.Date
  websiteLink    String?   // Organization website URL
  events         events[]
}

model events {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  createdAt   DateTime @db.Date
  date        DateTime @db.Date
  description String
  frequency   String
  lat         Float
  lng         Float
  location    String
  name        String
  updatedAt   DateTime @db.Date
  adminId     String   @db.ObjectId
  admin       admins   @relation(fields: [adminId], references: [id])
  photo       String?  // Field for storing Cloudinary URL
  registrationLink String?
  hasOpportunity Boolean? @default(false)  // New field to indicate if event has an opportunity
  opportunity String?    // New field to describe the volunteer opportunity
}

model members {
  id String @id @default(auto()) @map("_id") @db.ObjectId
}

model sessions {
  id      String @id @default(auto()) @map("_id") @db.ObjectId
  jwt     String
  user_id String @unique(map: "user_id_1")
}

model passwordresetotp {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  otp       String   // bcrypt-hashed 6-digit OTP
  expiresAt DateTime
  createdAt DateTime @default(now())
}